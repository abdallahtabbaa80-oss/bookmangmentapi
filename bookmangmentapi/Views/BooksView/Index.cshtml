@model IEnumerable<Book>
@{
    ViewData["Title"] = "Home";
    var books = Model.ToList();
    var latestBooks = books.OrderByDescending(book => book.Id).Take(5).ToList();
}

<section class="page-heading">
    <div>
        <p class="text-uppercase text-muted small fw-semibold mb-1">Library workspace</p>
        <h1 class="h2 mb-1">Book Management</h1>
        <p class="text-muted mb-0">Manage the in-memory catalog and keep the existing API available.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary" asp-controller="BooksView" asp-action="Create">Add book</a>
        <a class="btn btn-outline-primary" asp-controller="BooksView" asp-action="Search">Search ISBN</a>
    </div>
</section>

<section class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="summary-card">
            <span class="summary-label">Books</span>
            <strong>@books.Count</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="summary-card">
            <span class="summary-label">ISBNs</span>
            <strong>@books.Select(book => book.isbn).Distinct().Count()</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="summary-card">
            <span class="summary-label">Versions</span>
            <strong>@books.Select(book => new { book.isbn, book.version }).Distinct().Count()</strong>
        </div>
    </div>
</section>

<section class="content-panel">
    <div class="panel-title-row">
        <h2 class="h5 mb-0">Recent Books</h2>
        <a class="btn btn-sm btn-outline-secondary" asp-controller="BooksView" asp-action="List">View all</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Title</th>
                    <th>Author</th>
                    <th>ISBN</th>
                    <th>Version</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in latestBooks)
                {
                    <tr>
                        <td>@book.Id</td>
                        <td>@book.Title</td>
                        <td>@book.Author</td>
                        <td>@book.isbn</td>
                        <td>@book.version</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="BooksView" asp-action="Edit" asp-route-isbn="@book.isbn" asp-route-version="@book.version">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-controller="BooksView" asp-action="Delete" asp-route-isbn="@book.isbn" asp-route-version="@book.version">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
