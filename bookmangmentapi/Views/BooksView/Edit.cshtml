@model Book
@{
    ViewData["Title"] = "Edit Book";
}

<section class="page-heading">
    <div>
        <p class="text-uppercase text-muted small fw-semibold mb-1">Catalog</p>
        <h1 class="h2 mb-1">Edit Book</h1>
    </div>
</section>

<section class="form-panel">
    <form asp-action="Edit" method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input asp-for="Id" type="hidden" />

        <div class="col-md-6">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" required />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Author" class="form-label"></label>
            <input asp-for="Author" class="form-control" required />
            <span asp-validation-for="Author" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="YearPublished" class="form-label">Year Published</label>
            <input asp-for="YearPublished" class="form-control" type="number" />
            <span asp-validation-for="YearPublished" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="isbn" class="form-label">ISBN</label>
            <input asp-for="isbn" class="form-control" readonly />
        </div>

        <div class="col-md-4">
            <label asp-for="version" class="form-label">Version</label>
            <input asp-for="version" class="form-control" type="number" readonly />
        </div>

        <div class="col-12">
            <label asp-for="additionalDetails" class="form-label">Additional Details</label>
            <textarea asp-for="additionalDetails" class="form-control details-textarea" rows="6"></textarea>
            <span asp-validation-for="additionalDetails" class="text-danger"></span>
        </div>

        <div class="col-12 form-actions">
            <a class="btn btn-outline-secondary" asp-controller="BooksView" asp-action="List">Cancel</a>
            <button class="btn btn-primary" type="submit">Save</button>
        </div>
    </form>
</section>
