@model IEnumerable<Book>
@{
    ViewData["Title"] = "Books";
}

<section class="page-heading">
    <div>
        <p class="text-uppercase text-muted small fw-semibold mb-1">Catalog</p>
        <h1 class="h2 mb-1">Books</h1>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary" asp-controller="BooksView" asp-action="Create">Add book</a>
        <a class="btn btn-outline-primary" asp-controller="BooksView" asp-action="Search">Search ISBN</a>
    </div>
</section>

<section class="content-panel">
    <div class="table-responsive">
        <table class="table table-hover align-middle book-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Year Published</th>
                    <th>ISBN</th>
                    <th>Version</th>
                    <th>Additional Details</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model)
                {
                    <tr>
                        <td>@book.Id</td>
                        <td>@book.Title</td>
                        <td>@book.Author</td>
                        <td>@book.YearPublished</td>
                        <td>@book.isbn</td>
                        <td>@book.version</td>
                        <td class="details-cell">@book.additionalDetails</td>
                        <td class="text-end action-cell">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="BooksView" asp-action="Edit" asp-route-isbn="@book.isbn" asp-route-version="@book.version">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-controller="BooksView" asp-action="Delete" asp-route-isbn="@book.isbn" asp-route-version="@book.version">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
